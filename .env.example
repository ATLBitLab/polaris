NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Prefer a Supabase secret key for the API route that records
# anonymous quiz analytics. Do not expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=

# Optional legacy fallback if the project uses a service role key instead.
# SUPABASE_SERVICE_ROLE_KEY=
