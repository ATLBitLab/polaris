NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Prefer a Supabase secret key for the API route that records
# anonymous quiz analytics. Do not expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=

# Optional legacy fallback if the project uses a service role key instead.
# SUPABASE_SERVICE_ROLE_KEY=

# Set to "true" to render fake demo incident reports in any future surface
# that exposes user submissions. The fake records live in
# src/lib/fake-incident-reports.ts and are never written to the database.
NEXT_PUBLIC_SHOW_FAKE_INCIDENT_REPORTS=

# Server-only bearer token for POST /api/jobs/blind-incidents.
BLINDING_JOB_SECRET=

# Server-only bearer token automatically sent by Vercel Cron when configured.
# May be the same value as BLINDING_JOB_SECRET.
CRON_SECRET=

# Tinfoil powers voice transcription, report analysis, and research blinding.
TINFOIL_API_KEY=
TINFOIL_ANALYSIS_MODEL=
TINFOIL_BLINDING_MODEL=

# Cloudflare Turnstile gates draft creation on the /report intro page.
# For local development use Cloudflare's always-pass test keys:
#   site key:   1x00000000000000000000AA
#   secret key: 1x0000000000000000000000000000000AA
# See https://developers.cloudflare.com/turnstile/troubleshooting/testing/.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
